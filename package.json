{
  "name": "word-cloud-server",
  "version": "1.0.0",
  "description": "生词本词云 Web 应用后端：Express + MongoDB + JWT",
  "main": "server/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "NODE_ENV=production node server/server.js",
    "start:prod": "NODE_ENV=production node server/server.js",
    "dev": "NODE_ENV=development node --watch server/server.js",
    "build:css": "tailwindcss -i public/css/tailwind-input.css -o public/css/tailwind.css --minify"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
