# 复制为 .env.development / .env.production 后填写真实值
# server.js 会根据 NODE_ENV 自动加载对应文件，未匹配时回退到 .env
PORT=1234
MONGO_URI=xxx
JWT_SECRET=xxx
JWT_EXPIRES_IN=7d
# 允许跨域来源；本地与同源部署留空即可
CORS_ORIGIN=
# 外部是否通过 HTTPS 访问。true 时下发 HSTS + upgrade-insecure-requests；
# false（默认）保留为 HTTP 兼容，否则浏览器会强制升级到 https 导致 SSL 错。
HTTPS_ENABLED=false
# DeepSeek API Key，用于短文 AI 翻译功能
DEEPSEEK_API_KEY=
